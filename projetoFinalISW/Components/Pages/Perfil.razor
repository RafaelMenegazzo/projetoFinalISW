@page "/Perfil"
@rendermode InteractiveServer

@using projetoFinalISW.Components.Models
@using projetoFinalISW.Components.Services

@inject AluguelService AluguelService
@inject AuthService AuthService
@inject NavigationManager Navigation

<h3 class="mb-4">Perfil</h3>

@if (AuthService.UsuarioLogado == null)
{
    <div class="alert alert-warning">
        Você não está logado.
    </div>

    <button class="btn btn-primary" @onclick="IrParaLogin">Ir para Login</button>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-1">@AuthService.UsuarioLogado.Nome</h5>
            <p class="text-muted mb-0">@AuthService.UsuarioLogado.Email</p>
        </div>
    </div>

    <h4 class="mb-3">Livros alugados</h4>

    @if (alugueis.Count == 0)
    {
        <div class="alert alert-info">
            Você ainda não alugou nenhum livro.
        </div>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th>Livro</th>
                    <th>Data do aluguel</th>
                    <th>Data de devolução</th>
                    <th>Ação</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var aluguel in alugueis)
                {
                    <tr>
                        <td>@aluguel.Livro.Titulo</td>
                        <td>@aluguel.DataAluguel.ToShortDateString()</td>
                        <td>@aluguel.DataDevolucao?.ToShortDateString()</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => Renovar(aluguel.Id)">
                                Renovar +15 dias
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<Aluguel> alugueis = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.UsuarioLogado != null)
        {
            alugueis = await AluguelService.MeusLivros(AuthService.UsuarioLogado.Id);
        }
    }

    private async Task Renovar(int aluguelId)
    {
        await AluguelService.Renovar(aluguelId);

        if (AuthService.UsuarioLogado != null)
        {
            alugueis = await AluguelService.MeusLivros(AuthService.UsuarioLogado.Id);
        }
    }

    private void IrParaLogin()
    {
        Navigation.NavigateTo("/Login");
    }
}