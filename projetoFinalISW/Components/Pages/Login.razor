@page "/Login"

@using projetoFinalISW.Components.Services

@inject UsuarioService UsuarioService
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="row justify-content-center align-items-center"
     style="min-height: 75vh;">

    <div class="col-12 col-md-6 col-lg-4">

        <div class="text-center mb-4">
            <h1 class="fw-bold text-primary">
                Biblioteca Online
            </h1>

            <p class="text-muted">
                Entre para consultar e alugar livros
            </p>
        </div>

        <div class="card border-0 shadow">
            <div class="card-body p-4">

                <h3 class="text-center mb-4">
                    Login
                </h3>

                <div class="mb-3">
                    <label class="form-label">
                        Email
                    </label>

                    <InputText class="form-control"
                               type="email"
                               placeholder="seuemail@exemplo.com"
                               @bind-Value="email" />
                </div>

                <div class="mb-3">
                    <label class="form-label">
                        Senha
                    </label>

                    <InputText type="password"
                               class="form-control"
                               placeholder="Digite sua senha"
                               @bind-Value="senha" />
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-primary"
                            disabled="@entrando"
                            @onclick="Entrar">

                        @(entrando ? "Entrando..." : "Entrar")
                    </button>

                    <button class="btn btn-outline-primary"
                            @onclick="IrParaCadastro">
                        Criar uma conta
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(mensagem))
                {
                    <div class="alert alert-danger mt-3 mb-0">
                        @mensagem
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@code {
    private string email = "";
    private string senha = "";
    private string mensagem = "";
    private bool entrando;

    protected override void OnInitialized()
    {
        if (AuthService.EstaLogado)
        {
            Navigation.NavigateTo("/AlugarLivro");
        }
    }

    private async Task Entrar()
    {
        mensagem = "";

        if (string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(senha))
        {
            mensagem = "Preencha o email e a senha.";
            return;
        }

        entrando = true;

        try
        {
            var usuario =
                await UsuarioService.DoLogin(email.Trim(), senha);

            if (usuario == null)
            {
                mensagem = "Email ou senha inválidos.";
                return;
            }

            AuthService.DoLogin(usuario);

            Navigation.NavigateTo("/AlugarLivro");
        }
        catch (Exception ex)
        {
            mensagem =
                $"Não foi possível realizar o login: {ex.Message}";
        }
        finally
        {
            entrando = false;
        }
    }

    private void IrParaCadastro()
    {
        Navigation.NavigateTo("/CadastroUser");
    }
}