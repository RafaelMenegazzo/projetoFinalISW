@rendermode InteractiveServer
@page "/CadastroUser"

@using projetoFinalISW.Components.Models
@using projetoFinalISW.Components.Services

@inject UsuarioService UsuarioService
@inject NavigationManager Navigation

<h3 class="mb-4">Cadastro de Usuário</h3>

<div class="row justify-content-center">
    <div class="col-md-6">
        <EditForm Model="usuario" OnValidSubmit="Cadastrar">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="mb-3">
                <label class="form-label">Nome</label>
                <InputText class="form-control" @bind-Value="usuario.Nome" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="usuario.Email" />
            </div>

            <div class="mb-3">
                <label class="form-label">Senha</label>
                <InputText class="form-control" type="password" @bind-Value="senha" />
            </div>

            <button class="btn btn-primary">Cadastrar</button>
            <button type="button" class="btn btn-outline-secondary ms-2" @onclick="IrParaLogin">Voltar</button>
        </EditForm>

        @if (!string.IsNullOrEmpty(mensagem))
        {
            <div class="alert alert-info mt-3">@mensagem</div>
        }
    </div>
</div>

@code {
    private Usuario usuario = new();
    private string senha = "";
    private string mensagem = "";

    async Task Cadastrar()
    {
        bool sucesso = await UsuarioService.CadastrarUsuario(usuario, senha);

        mensagem = sucesso ? "Usuário cadastrado com sucesso!" : "Email já cadastrado.";

        if (sucesso)
        {
            usuario = new();
            senha = "";
        }
    }

    private void IrParaLogin()
    {
        Navigation.NavigateTo("/Login");
    }
}