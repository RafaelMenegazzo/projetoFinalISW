@page "/CadastroUser"

@using projetoFinalISW.Components.Models
@using projetoFinalISW.Components.Services

@inject UsuarioService UsuarioService
@inject NavigationManager Navigation

<PageTitle>Criar conta</PageTitle>

<div class="row justify-content-center align-items-center"
     style="min-height: 75vh;">

    <div class="col-12 col-md-7 col-lg-5">

        <div class="text-center mb-4">
            <h1 class="fw-bold text-primary">
                Biblioteca Online
            </h1>

            <p class="text-muted">
                Crie sua conta para começar
            </p>
        </div>

        <div class="card border-0 shadow">
            <div class="card-body p-4">

                <h3 class="text-center mb-4">
                    Cadastro de usuário
                </h3>

                <EditForm Model="usuario"
                          OnValidSubmit="Cadastrar">

                    <DataAnnotationsValidator />

                    <ValidationSummary class="alert alert-danger" />

                    <div class="mb-3">
                        <label class="form-label">
                            Nome
                        </label>

                        <InputText class="form-control"
                                   placeholder="Digite seu nome"
                                   @bind-Value="usuario.Nome" />

                        <ValidationMessage For="@(() => usuario.Nome)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Email
                        </label>

                        <InputText class="form-control"
                                   type="email"
                                   placeholder="seuemail@exemplo.com"
                                   @bind-Value="usuario.Email" />

                        <ValidationMessage For="@(() => usuario.Email)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Senha
                        </label>

                        <InputText class="form-control"
                                   type="password"
                                   placeholder="Digite sua senha"
                                   @bind-Value="senha" />
                    </div>

                    <div class="d-grid gap-2">

                        <button class="btn btn-primary"
                                disabled="@cadastrando">

                            @(cadastrando
                                ? "Cadastrando..."
                                : "Cadastrar")
                        </button>

                        <button type="button"
                                class="btn btn-outline-secondary"
                                @onclick="IrParaLogin">

                            Voltar para o login
                        </button>

                    </div>

                </EditForm>

                @if (!string.IsNullOrEmpty(mensagem))
                {
                    <div class="alert @classeMensagem mt-3 mb-0">
                        @mensagem
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@code {
    private Usuario usuario = new();
    private string senha = "";
    private string mensagem = "";
    private string classeMensagem = "alert-info";
    private bool cadastrando;

    private async Task Cadastrar()
    {
        mensagem = "";

        if (string.IsNullOrWhiteSpace(senha))
        {
            classeMensagem = "alert-danger";
            mensagem = "A senha é obrigatória.";
            return;
        }

        if (senha.Length < 6)
        {
            classeMensagem = "alert-danger";
            mensagem = "A senha deve conter pelo menos 6 caracteres.";
            return;
        }

        cadastrando = true;

        try
        {
            bool sucesso =
                await UsuarioService.CadastrarUsuario(
                    usuario,
                    senha);

            if (!sucesso)
            {
                classeMensagem = "alert-danger";
                mensagem = "Este email já está cadastrado.";
                return;
            }

            classeMensagem = "alert-success";
            mensagem = "Usuário cadastrado com sucesso!";

            usuario = new Usuario();
            senha = "";

            await Task.Delay(1000);

            Navigation.NavigateTo("/Login");
        }
        catch (Exception ex)
        {
            classeMensagem = "alert-danger";
            mensagem =
                $"Não foi possível cadastrar: {ex.Message}";
        }
        finally
        {
            cadastrando = false;
        }
    }

    private void IrParaLogin()
    {
        Navigation.NavigateTo("/Login");
    }
}