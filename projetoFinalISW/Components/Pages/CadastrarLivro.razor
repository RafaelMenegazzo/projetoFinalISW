@rendermode InteractiveServer
@page "/CadastrarLivro"

@using projetoFinalISW.Components.Models
@using projetoFinalISW.Components.Services

@inject LivroService LivroService

<h3 class="mb-4">Cadastrar Livro</h3>

<EditForm Model="livro" OnValidSubmit="CadastroLivro">
    <DataAnnotationsValidator />
    <ValidationSummary class="alert alert-danger" />

    <div class="row">
        <div class="col-md-8 mb-3">
            <label class="form-label">Título</label>
            <InputText class="form-control" @bind-Value="livro.Titulo" />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Ano de Publicação</label>
            <InputNumber class="form-control" @bind-Value="livro.AnoPublicacao" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Sinopse</label>
        <InputTextArea class="form-control" rows="4" @bind-Value="livro.Sinopse" />
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Autor</label>
            <InputText class="form-control" @bind-Value="livro.Autor" />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Editora</label>
            <InputText class="form-control" @bind-Value="livro.Editora" />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Gênero</label>
            <InputText class="form-control" @bind-Value="livro.Genero" />
        </div>
    </div>

    <div class="form-check mb-3">
        <InputCheckbox class="form-check-input" @bind-Value="livro.Disponivel" />
        <label class="form-check-label">Disponível para aluguel</label>
    </div>

    <button class="btn btn-primary">Salvar</button>

    @if (!string.IsNullOrEmpty(mensagem))
    {
        <div class="alert alert-success mt-3">@mensagem</div>
    }
</EditForm>

@code {
    Livro livro = new() { Disponivel = true };
    string mensagem = "";

    async Task CadastroLivro()
    {
        await LivroService.CadastroLivro(livro);
        livro = new() { Disponivel = true };
        mensagem = "Livro cadastrado com sucesso!";
    }
}