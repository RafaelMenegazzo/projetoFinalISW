@rendermode InteractiveServer
@page "/AlugarLivro"

@using projetoFinalISW.Components.Models
@using projetoFinalISW.Components.Services

@inject AluguelService AluguelService
@inject AuthService AuthService
@inject S3Service S3Service

<h3 class="mb-4">Livros disponíveis</h3>

@if (AuthService.UsuarioLogado == null)
{
    <div class="alert alert-warning">
        Faça login para alugar um livro.
    </div>
}
else if (livros.Count == 0)
{
    <div class="alert alert-info">
        Nenhum livro disponível no momento.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var livro in livros)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    @if (!string.IsNullOrWhiteSpace(livro.CapaChave))
                    {
                        <img src="@S3Service.ObterUrlTemporaria(livro.CapaChave)"
                             class="card-img-top"
                             alt="Capa de @livro.Titulo"
                             style="height: 320px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center"
                             style="height: 320px;">
                            <span class="text-muted">Sem capa</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@livro.Titulo</h5>

                        <p class="mb-1">
                            <strong>Autor:</strong> @livro.Autor
                        </p>

                        <p class="mb-1">
                            <strong>Editora:</strong> @livro.Editora
                        </p>

                        <p class="mb-3">
                            <strong>Gênero:</strong> @livro.Genero
                        </p>

                        <p class="text-muted">
                            @livro.Sinopse
                        </p>

                        <button class="btn btn-primary mt-auto"
                                @onclick="() => Alugar(livro.Id)">
                            Alugar
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Livro> livros = new();

    protected override async Task OnInitializedAsync()
    {
        livros = await AluguelService.LivrosDisponiveis();
    }

    private async Task Alugar(int livroId)
    {
        if (AuthService.UsuarioLogado == null)
            return;

        await AluguelService.AlugarLivro(
            livroId,
            AuthService.UsuarioLogado.Id);

        livros = await AluguelService.LivrosDisponiveis();
    }
}